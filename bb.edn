{:paths ["scripts"]
 :deps {org.babashka/http-client {:mvn/version "0.4.22"}}
 :tasks
 {:requires ([babashka.cli :as cli]
             [robocode] [codesize] [battle] [install] [benchmark] [publish] [extract-bot] [rumble-roster] [rumble-stats] [roborumble])

  robocode {:doc "Launch Robocode"
            :task (robocode/launch! nil)}

  build {:doc "Compile bots (delegates to Gradle)"
         :task (babashka.process/shell
                {:extra-env {"JAVA_HOME" "/Users/pez/.sdkman/candidates/java/21.0.11-amzn"}}
                "./gradlew" "build")}

  codesize {:doc "Check codesize: bb codesize pez.mini.Pugilist OR bb codesize --code [code-string] (stdin if omitted)"
            :task (let [opts (cli/parse-opts *command-line-args*
                                            {:coerce {:code :boolean}
                                             :args->opts [:arg]})]
                    (if (:code opts)
                      (codesize/check-code! {:code (or (:arg opts) (slurp *in*))})
                      (codesize/check! {:bot (:arg opts)})))}

  battle {:doc "Run headless battles: bb battle pez.mini.Pugilist [rounds] [opponent1 opponent2 ...]"
          :task (let [{:keys [opts args]} (cli/parse-args *command-line-args*
                                                         {:args->opts [:bot :rounds]})]
                  (battle/battle! {:bot (:bot opts)
                                   :rounds (or (:rounds opts) 35)
                                   :opponents (when (seq args) args)}))}

  install {:doc "Install a bot from RoboRumble participants: bb install voidious.mini.Komarious (or --all)"
           :task (let [opts (cli/parse-opts *command-line-args*
                                           {:coerce {:all :boolean}
                                            :args->opts [:bot]})]
                   (install/install! {:bot (when-not (:all opts) (:bot opts))
                                      :all (boolean (:all opts))}))}

  benchmark {:doc "Run benchmark, queued if the same execution target is already running: bb benchmark <bot> [rounds] [match-length] [commit] [roster] [--local] [--workers N]"
             :task (let [opts (cli/parse-opts *command-line-args*
                                             {:coerce {:workers :int :local :boolean}
                                              :args->opts [:bot :rounds :match-length :commit :roster]})]
                     (benchmark/queued-benchmark! {:bot (:bot opts)
                                                   :rounds (or (:rounds opts) 100)
                                                   :match-length (or (:match-length opts) 35)
                                                   :commit (let [c (:commit opts)]
                                                             (when-not (= "-" c) c))
                                                   :roster (:roster opts)
                                                   :local? (boolean (:local opts))
                                                   :num-workers (:workers opts)}))}

  benchmark-report {:doc "Render benchmark log in report format: bb benchmark-report <log.edn> [output.md]"
                    :task (benchmark/report-log! (cli/parse-opts *command-line-args*
                                                                {:args->opts [:log :output]}))}

  benchmark-parallel {:doc "Run parallel local benchmarks, queued if a local benchmark is already running: bb benchmark-parallel <bot> <rounds> <ref1> [ref2] ... [current]"
                      :task (let [{:keys [opts args]} (cli/parse-args *command-line-args*
                                                                      {:args->opts [:bot :rounds]})]
                              (benchmark/queued-benchmark-parallel!
                               {:bot (:bot opts)
                                :rounds (or (:rounds opts) 105)
                                :match-length 35
                                :refs (mapv (fn [r] (when-not (= "current" r) r)) args)}))}

  publish {:doc "Build and deploy to Netlify"
           :task (publish/publish!)}

  roborumble {:doc "Run RoboRumble client (remote by default): bb roborumble [--local] [--workers N]"
              :task (let [opts (cli/parse-opts *command-line-args*
                                              {:coerce {:workers :int :local :boolean}})]
                      (roborumble/run! {:local? (boolean (:local opts))
                                        :num-workers (:workers opts)}))}

  extract-bot {:doc "Copy a bot jar to research/bots: bb extract-bot sheldor.mini.Foilist"
               :task (extract-bot/extract! {:bot (first *command-line-args*)})}

  rumble-roster {:doc "Generate benchmark roster from LiteRumble: bb rumble-roster [--bot 'Bot 1.0'] [--column APS] [--game minirumble] [--output file.edn]"
                 :task (rumble-roster/generate! *command-line-args*)}

  full-roster {:doc "Generate full benchmark roster from LiteRumble, excluding own bot: bb full-roster mini pez.mini.Pugilist"
               :task (rumble-roster/generate-full! *command-line-args*)}

  rumble-stats {:doc "Query LiteRumble stats: bb rumble-stats <url-or-bot-version> [--rankings] [--sort COL] [--head N] [--tail N] [--asc] [--filter-bots PATTERNS] [--columns] [--edn]"
                :task (rumble-stats/stats! *command-line-args*)}}}
